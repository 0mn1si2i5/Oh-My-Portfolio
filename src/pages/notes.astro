---
import BaseLayout from '../components/BaseLayout.astro';
import Localized from '../components/Localized.astro';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="Notes" description="Future notes by Jiaming Li.">
  <section class="notes page-width">
    <p class="eyebrow"><Localized en="Notes" zh="随笔" /></p>
    <h1><Localized en="Room for things not finished yet." zh="记录尚未结束的问题。" /></h1>
    <p class="lead"><Localized en="This is where I will leave short notes on making, research, and the questions that survive after a project ships." zh="这里将发布关于产品开发、研究过程及相关思考的短文。" /></p>
    <div class="empty-state"><span aria-hidden="true">◌</span><p><Localized en="No notes published yet." zh="暂未发布文章。" /></p><p class="muted"><Localized en="For now, the projects are the notes." zh="目前可以先从项目页了解我的工作。" /></p><a href={`${base}#work`}><Localized en="Return to selected work" zh="返回精选项目" /> <span aria-hidden="true">↑</span></a></div>
  </section>
</BaseLayout>

<style>
  .page-width { width: min(1180px, calc(100% - 3rem)); margin: 0 auto; }.notes { min-height: calc(100vh - 178px); padding: clamp(5rem, 12vw, 10rem) 0; }.eyebrow { margin: 0; color: var(--muted); font-size: .78rem; font-weight: 650; letter-spacing: .075em; text-transform: uppercase; }h1 { margin: 2.5rem 0; font-size: clamp(3.8rem, 8vw, 8rem); font-weight: 560; line-height: .9; letter-spacing: -.07em; }.lead { max-width: 560px; font-size: clamp(1.2rem, 2.3vw, 1.85rem); line-height: 1.3; letter-spacing: -.03em; }.empty-state { max-width: 510px; margin-top: 6rem; padding: 2rem 0; border-top: 1px solid var(--line); }.empty-state > span { display: inline-block; margin-bottom: .8rem; color: var(--violet); font-size: 2.1rem; }.empty-state p { margin: .15rem 0; }.muted { color: var(--muted); }.empty-state a { display: inline-block; margin-top: 1.4rem; font-weight: 650; } @media (max-width: 560px) { .page-width { width: min(100% - 2rem, 1180px); } h1 { font-size: clamp(3.6rem, 17vw, 5.4rem); } }
</style>
