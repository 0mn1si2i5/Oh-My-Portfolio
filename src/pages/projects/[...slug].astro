---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../components/BaseLayout.astro';
import ProjectMedia from '../../components/ProjectMedia.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({ params: { slug: project.id }, props: { project } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title={project.data.title} description={project.data.summary}>
  <article class:list={['project-page', `accent-${project.data.accent}`]}>
    <header class="project-hero page-width">
      <p class="eyebrow"><a href={`${base}#work`}>Selected work</a> <span aria-hidden="true">/</span> {project.data.year}</p>
      <div class="hero-grid"><div><h1>{project.data.title}</h1><p class="summary">{project.data.summary}</p></div><dl><div><dt>Status</dt><dd>{project.data.status}</dd></div><div><dt>My focus</dt><dd>{project.data.role}</dd></div></dl></div>
    </header>
    <section class="media-section page-width"><ProjectMedia project={project} /></section>
    <section class="project-body page-width"><div class="body-label">Exploration</div><div class="prose"><Content /></div></section>
    <section class="explore-section page-width" aria-labelledby="explore-title"><p class="eyebrow">Explore</p><h2 id="explore-title">Continue from here.</h2><div class="links">{project.data.links.map((link) => <a href={link.href} target="_blank" rel="noreferrer">{link.label} <span aria-hidden="true">↗</span></a>)}</div></section>
  </article>
</BaseLayout>

<style>
  .page-width { width: min(1180px, calc(100% - 3rem)); margin: 0 auto; }.eyebrow { margin: 0; color: var(--muted); font-size: .78rem; font-weight: 650; letter-spacing: .075em; text-transform: uppercase; }.eyebrow a { color: inherit; text-decoration: none; }.project-hero { padding: clamp(4rem, 9vw, 8rem) 0 4rem; }.hero-grid { display: grid; grid-template-columns: 1.45fr .55fr; gap: 4rem; align-items: end; }.project-hero h1, h2 { margin: 2.2rem 0 1.25rem; font-size: clamp(3.8rem, 8vw, 8rem); font-weight: 560; line-height: .9; letter-spacing: -.07em; }.summary { max-width: 720px; margin-bottom: 0; font-size: clamp(1.3rem, 2.4vw, 2rem); line-height: 1.25; letter-spacing: -.035em; }.project-hero dl { margin: 0; }.project-hero dl div { padding: 1.1rem 0; border-top: 1px solid var(--line); }.project-hero dt { margin-bottom: .4rem; color: var(--muted); font-size: .75rem; font-weight: 650; letter-spacing: .08em; text-transform: uppercase; }.project-hero dd { margin: 0; font-size: .98rem; }.media-section { padding-bottom: 7rem; }.project-body { display: grid; grid-template-columns: .45fr 1fr; gap: 4rem; padding: 6rem 0; border-top: 1px solid var(--line); }.body-label { color: var(--muted); font-size: .78rem; font-weight: 650; letter-spacing: .075em; text-transform: uppercase; }.prose { max-width: 700px; }.prose :global(h2) { margin: 0 0 1rem; font-size: clamp(2rem, 3.5vw, 3.3rem); line-height: 1; }.prose :global(p) { margin: 0 0 3.3rem; font-size: clamp(1.08rem, 1.6vw, 1.3rem); line-height: 1.55; }.prose :global(a) { color: var(--accent); }.explore-section { padding: 6rem 0 8rem; border-top: 1px solid var(--line); }.explore-section h2 { margin-top: 1.1rem; font-size: clamp(2.4rem, 5vw, 4.6rem); }.links { display: flex; flex-wrap: wrap; gap: .75rem; margin-top: 3rem; }.links a { padding: .8rem 1rem; border: 1px solid var(--line); border-radius: 999px; font-weight: 650; text-decoration: none; }.links a:hover { color: var(--paper); background: var(--ink); border-color: var(--ink); }.accent-violet { --accent: var(--violet); }.accent-coral { --accent: var(--coral); }.accent-blue { --accent: var(--blue); } @media (max-width: 760px) { .hero-grid, .project-body { grid-template-columns: 1fr; gap: 2.5rem; }.media-section { padding-bottom: 5rem; }.project-body, .explore-section { padding: 4rem 0; } } @media (max-width: 560px) { .page-width { width: min(100% - 2rem, 1180px); }.project-hero h1 { font-size: clamp(3.6rem, 17vw, 5.4rem); } }
</style>
