---
import type { CollectionEntry } from 'astro:content';
import Localized from './Localized.astro';

interface Props { project: CollectionEntry<'projects'>; compact?: boolean; }
const { project, compact = false } = Astro.props;
const { media, title, accent } = project.data;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const asset = (path?: string) => path ? `${base}${path.replace(/^\//, '')}` : undefined;
const imageSource = compact && media.preview ? media.preview : media.src;
---

{media.type === 'video' && media.src ? (
  <div class:list={['project-media', `accent-${accent}`, { compact }]}>
    {compact ? (
      <img src={asset(media.poster)} alt={media.alt.en} data-alt-en={media.alt.en} data-alt-zh={media.alt.zh} loading="lazy" />
    ) : (
      <video controls preload="metadata" poster={asset(media.poster)} aria-label={`${title.en} video preview`}>
        <source src={asset(media.src)} type="video/mp4" />
        <Localized en="Your browser does not support embedded video." zh="你的浏览器不支持嵌入式视频。" /> <a href={asset(media.src)}><Localized en="Download the preview" zh="下载预览视频" /></a>.
      </video>
    )}
  </div>
) : media.type === 'image' && media.src ? (
  <div class:list={['project-media', 'image-media', `accent-${accent}`, { compact, 'preview-media': compact && Boolean(media.preview) }]}>
    <img src={asset(imageSource)} alt={media.alt.en} data-alt-en={media.alt.en} data-alt-zh={media.alt.zh} loading={compact ? 'lazy' : 'eager'} />
  </div>
) : (
  <div class:list={['project-media', 'media-placeholder', `accent-${accent}`, { compact }]} role="img" aria-label={media.alt.en}>
    <div class="placeholder-line short"></div>
    <div class="placeholder-line"></div>
    <div class="placeholder-orb"></div>
    <span><Localized en="Project visuals in progress" zh="项目视觉素材制作中" /></span>
  </div>
)}

<style>
  .project-media { position: relative; overflow: hidden; aspect-ratio: 16 / 9; background: var(--surface); border: 1px solid var(--line); border-radius: 18px; }
  video, img { display: block; width: 100%; height: 100%; object-fit: cover; background: #111; }
  .image-media img { object-fit: contain; background: var(--surface); }
  .preview-media { aspect-ratio: 4 / 3; }
  .preview-media img { object-fit: cover; }
  .media-placeholder { padding: clamp(1.2rem, 3vw, 2rem); display: flex; flex-direction: column; justify-content: flex-end; gap: .7rem; }
  .media-placeholder::before { content: ''; position: absolute; inset: 11% 15%; border: 1px solid color-mix(in srgb, var(--accent) 50%, transparent); border-radius: 12px; transform: rotate(-5deg); }
  .placeholder-line { position: relative; z-index: 1; height: 9px; width: 52%; border-radius: 999px; background: color-mix(in srgb, var(--accent) 35%, var(--surface)); }
  .placeholder-line.short { width: 28%; }
  .placeholder-orb { position: absolute; width: 26%; aspect-ratio: 1; top: 13%; right: 14%; border-radius: 50%; background: color-mix(in srgb, var(--accent) 48%, transparent); filter: blur(1px); }
  .media-placeholder span { position: relative; z-index: 1; color: var(--muted); font-size: .82rem; }
  .accent-violet { --accent: var(--violet); } .accent-coral { --accent: var(--coral); } .accent-blue { --accent: var(--blue); }
</style>
