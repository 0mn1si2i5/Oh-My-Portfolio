---
import Localized from './Localized.astro';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const asset = (path: string) => `${base}${path.replace(/^\//, '')}`;

const stages = [
  {
    number: '01',
    label: { en: 'Parse', zh: '解析链接' },
    title: { en: 'Start with a music link.', zh: '输入一个音乐链接。' },
    copy: {
      en: 'Paste a Spotify, Apple Music, NetEase Cloud Music, or QQ Music link. A full share message works too; Side B extracts the link before it starts resolving the song.',
      zh: '可以粘贴 Spotify、Apple Music、网易云音乐或 QQ 音乐链接；带着歌名和短链的完整分享消息也可以直接使用。Side B 会先提取链接，再开始解析歌曲。',
    },
    screens: [
      { file: '01-personal-paste', alt: { en: 'A natural-language NetEase share message pasted into Side B songs.', zh: '一段包含网易云短链的分享消息被粘贴到 Side B 的歌曲页。' } },
    ],
  },
  {
    number: '02',
    label: { en: 'Resolve', zh: '获取歌曲与链接' },
    title: { en: 'Get the track and its platform links.', zh: '获取歌曲信息和全平台链接。' },
    copy: {
      en: 'Side B resolves the incoming link into one track page: title, artist, artwork, original source, and the available listening destinations are all in one place.',
      zh: 'Side B 会把传来的链接收敛成同一张歌曲页：歌名、歌手、封面、原始来源和可用去向都放在一起。这样在跳转之前，先确认大家说的是不是同一首歌。',
    },
    screens: [
      { file: '02-personal-canonical-detail', alt: { en: 'The resolved Creep track page, showing source and available listening destinations.', zh: '解析后的 Creep 歌曲页，展示来源与可用的听歌去向。' } },
    ],
  },
  {
    number: '03',
    label: { en: 'Continue', zh: '继续下一步' },
    title: { en: 'Choose what to do with the result.', zh: '解析完成后，决定怎么继续。' },
    copy: {
      en: 'From the song page, people can save a track, open any available platform link, or send it to a room. Once it is in a room, later replies and reactions stay attached to the song card.',
      zh: '从歌曲页可以收藏歌曲、打开任意可用的平台链接，或把它发送到房间。发送到房间后，后续回复和表情回应会继续挂在歌曲卡片上。',
    },
    screens: [
      { file: '07-send-to-room-sheet', alt: { en: 'The Side B sheet for choosing a room to send a resolved song to.', zh: 'Side B 中为解析后的歌曲选择发送房间的操作层。' } },
    ],
  },
];
---

<section class="side-b-gallery" aria-labelledby="side-b-gallery-title">
  <header class="gallery-intro">
    <p class="eyebrow"><Localized en="How it works" zh="实际使用" /></p>
    <h2 id="side-b-gallery-title"><Localized en="Parse the link, get the platform links, then decide what to do next." zh="解析链接，获取全平台链接，再决定怎么继续。" /></h2>
  </header>

  <div class="stages">
    {stages.map((stage, index) => (
      <article class:list={['stage', { reversed: index % 2 === 1 }]}>
        <div class="stage-copy">
          <p class="stage-number">{stage.number} <span><Localized {...stage.label} /></span></p>
          <h3><Localized {...stage.title} /></h3>
          <p><Localized {...stage.copy} /></p>
        </div>
        <div class="stage-screens">
          {stage.screens.map((screen) => (
            <figure>
              <img
                src={asset(`/media/side-b/${screen.file}.webp`)}
                alt={screen.alt.en}
                data-alt-en={screen.alt.en}
                data-alt-zh={screen.alt.zh}
                loading="lazy"
              />
            </figure>
          ))}
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .side-b-gallery { margin: 5rem 0 5.5rem; padding-top: 5rem; border-top: 1px solid var(--line); }
  .eyebrow, .stage-number { margin: 0; color: var(--muted); font-size: .78rem; font-weight: 650; letter-spacing: .075em; text-transform: uppercase; }
  .gallery-intro h2 { max-width: 620px; margin: 1.1rem 0 4rem; font-size: clamp(2rem, 3.5vw, 3.3rem); line-height: 1; letter-spacing: -.055em; }
  .stages { display: grid; gap: 5rem; }
  .stage { display: grid; grid-template-columns: minmax(0, 1fr) minmax(240px, 340px); gap: clamp(2rem, 7vw, 6rem); align-items: center; }
  .stage.reversed { grid-template-columns: minmax(240px, 340px) minmax(0, 1fr); }
  .stage.reversed .stage-copy { order: 2; }
  .stage.reversed .stage-screens { order: 1; }
  .stage-copy { max-width: 440px; }
  .stage-number span { margin-left: .45rem; color: var(--ink); }
  .stage-copy h3 { margin: .75rem 0 1rem; font-size: clamp(1.35rem, 2.3vw, 2rem); line-height: 1.08; letter-spacing: -.045em; }
  .stage-copy > p:last-child { margin: 0; font-size: 1.02rem; line-height: 1.65; }
  .stage-screens { width: min(100%, 270px); justify-self: end; }
  figure { margin: 0; padding: 6px; background: #131316; border-radius: 26px; box-shadow: 0 17px 35px rgba(20, 20, 30, .16); }
  img { display: block; width: 100%; border-radius: 20px; }
  @media (max-width: 680px) {
    .side-b-gallery { margin: 4rem 0; padding-top: 4rem; }
    .gallery-intro h2 { margin-bottom: 3.2rem; }
    .stages { gap: 4.5rem; }
    .stage, .stage.reversed { grid-template-columns: 1fr; gap: 1.8rem; }
    .stage.reversed .stage-copy, .stage.reversed .stage-screens { order: initial; }
    .stage-screens { width: min(100%, 280px); justify-self: start; }
  }
</style>
