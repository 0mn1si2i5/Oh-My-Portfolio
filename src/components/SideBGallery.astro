---
import Localized from './Localized.astro';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const asset = (path: string) => `${base}${path.replace(/^\//, '')}`;

const groups = [
  {
    number: '01',
    label: { en: 'Resolve a link', zh: '把链接变成可用歌曲' },
    title: { en: 'Paste once, then get the song and the links you need.', zh: '粘贴一次，拿到歌曲信息和可用链接。' },
    copy: {
      en: 'A shared link or its full share message becomes a track page with the source and available listening destinations.',
      zh: '无论是一条音乐链接，还是完整的分享文案，解析后都会得到歌曲信息、原始来源和可用的全平台链接。',
    },
    screens: [
      {
        file: '01-parse-link',
        title: { en: 'Paste a share message', zh: '粘贴分享文案' },
        copy: { en: 'The song page accepts supported music links and full NetEase share messages.', zh: '歌曲页可以直接接收支持的平台链接，也可以粘贴完整的网易云分享文案。' },
        alt: { en: 'A NetEase Cloud Music share message pasted into Side B on an iPhone.', zh: '一段网易云音乐分享文案被粘贴到 iPhone 上的 Side B 歌曲页。' },
      },
      {
        file: '02-platform-links',
        title: { en: 'Open the available services', zh: '查看可用平台链接' },
        copy: { en: 'The resolved track page keeps the artwork, source, and available service links together.', zh: '解析后的歌曲页把封面、来源和可用的平台链接放在一起。' },
        alt: { en: 'The resolved Creep song page in Side B, showing its original source and four music-service buttons.', zh: 'Side B 中解析后的《Creep》歌曲页，展示原始来源和四个音乐平台按钮。' },
      },
    ],
  },
  {
    number: '02',
    label: { en: 'Keep it personal and social', zh: '留在歌单和对话里' },
    title: { en: 'Save a track for yourself, or keep the conversation around it.', zh: '把歌留进自己的歌单，或留在正在进行的对话里。' },
    copy: {
      en: 'Resolved songs can be saved to a personal playlist or shared into a room, where the discussion remains attached to the song.',
      zh: '解析后的歌曲可以加入个人歌单，也可以分享到房间；房间里的讨论会继续围绕这首歌展开。',
    },
    screens: [
      {
        file: '03-favorites-playlist',
        title: { en: 'Keep a personal playlist', zh: '保存到个人歌单' },
        copy: { en: 'Saved tracks form a playlist that can be returned to later.', zh: '收藏过的歌曲会留在歌单里，之后随时可以再找回来。' },
        alt: { en: 'The Side B Favorites playlist on an iPhone, with saved tracks including Creep and Maroon.', zh: 'iPhone 上的 Side B「已收藏」歌单，包含《Creep》和《Maroon》等已保存歌曲。' },
      },
      {
        file: '04-rooms-list',
        title: { en: 'Find the right room', zh: '进入合适的房间' },
        copy: { en: 'Rooms are organized around the people and listening contexts that give a recommendation its meaning.', zh: '不同的房间对应不同的人和听歌场景，让推荐保留它原来的语境。' },
        alt: { en: 'The Side B rooms list on an iPhone, with Daily Finds, Side B Club, and Late Night Loop.', zh: 'iPhone 上的 Side B 房间列表，包含 Daily Finds、Side B Club 和 Late Night Loop。' },
      },
      {
        file: '05-room-conversation',
        title: { en: 'Discuss around the song', zh: '围绕歌曲继续讨论' },
        copy: { en: 'Song cards keep the later reply and emoji reactions visible in the same conversation.', zh: '歌曲卡片会把后续回复和表情回应保留在同一段对话里。' },
        alt: { en: 'A Side B listening-room conversation with song cards, a quoted reply, and emoji reactions.', zh: 'Side B 听歌房间中的对话，包含歌曲卡片、引用回复和表情回应。' },
      },
    ],
  },
];
---

<section class="side-b-gallery" aria-labelledby="side-b-gallery-title">
  <header class="gallery-intro">
    <p class="eyebrow"><Localized en="In use" zh="实际使用" /></p>
    <h2 id="side-b-gallery-title"><Localized en="Parse a song link, get platform links, then save, share, open, or keep talking." zh="解析歌曲链接，获取全平台链接，再收藏、分享、跳转或继续讨论。" /></h2>
  </header>

  <div class="groups">
    {groups.map((group) => (
      <section class="capability-group" aria-label={group.label.en} data-label-zh={group.label.zh}>
        <header class="group-copy">
          <p class="group-number">{group.number} <span><Localized {...group.label} /></span></p>
          <h3><Localized {...group.title} /></h3>
          <p><Localized {...group.copy} /></p>
        </header>

        <div class="capability-list">
          {group.screens.map((screen, index) => (
            <article class:list={['capability', { reversed: index % 2 === 1 }]}>
              <div class="capability-copy">
                <h4><Localized {...screen.title} /></h4>
                <p><Localized {...screen.copy} /></p>
              </div>
              <figure>
                <img
                  src={asset(`/media/side-b/${screen.file}.webp`)}
                  alt={screen.alt.en}
                  data-alt-en={screen.alt.en}
                  data-alt-zh={screen.alt.zh}
                  loading="eager"
                />
              </figure>
            </article>
          ))}
        </div>
      </section>
    ))}
  </div>
</section>

<style>
  .side-b-gallery { margin: 5rem 0 5.5rem; padding-top: 5rem; border-top: 1px solid var(--line); }
  .eyebrow, .group-number { margin: 0; color: var(--muted); font-size: .78rem; font-weight: 650; letter-spacing: .075em; text-transform: uppercase; }
  .gallery-intro h2 { max-width: 720px; margin: 1.1rem 0 4rem; font-size: clamp(2rem, 3.5vw, 3.3rem); line-height: 1; letter-spacing: -.055em; }
  .groups { display: grid; gap: 6rem; }
  .capability-group { display: grid; gap: 3.5rem; }
  .group-copy { max-width: 520px; }
  .group-number span { margin-left: .45rem; color: var(--ink); }
  .group-copy h3 { margin: .75rem 0 1rem; font-size: clamp(1.45rem, 2.3vw, 2.15rem); line-height: 1.08; letter-spacing: -.045em; }
  .group-copy > p:last-child, .capability-copy p { margin: 0; font-size: 1rem; line-height: 1.65; }
  .capability-list { display: grid; gap: 5.5rem; }
  .capability { display: grid; gap: 1.4rem; }
  .capability.reversed figure { justify-self: start; }
  .capability-copy { max-width: 450px; }
  .capability-copy h4 { margin: 0 0 .75rem; font-size: 1.18rem; line-height: 1.2; letter-spacing: -.025em; }
  figure { width: min(100%, 276px); justify-self: end; margin: 0; padding: 8px; overflow: hidden; background: linear-gradient(145deg, #2c2c31, #080809 28%, #18181b); border: 1px solid rgba(255, 255, 255, .18); border-radius: 38px; box-shadow: 0 20px 42px rgba(20, 20, 30, .18), inset 0 0 0 1px rgba(0, 0, 0, .3); }
  img { display: block; width: 100%; border-radius: 29px; }
  @media (max-width: 680px) {
    .side-b-gallery { margin: 4rem 0; padding-top: 4rem; }
    .gallery-intro h2 { margin-bottom: 3.2rem; }
    .groups { gap: 4.5rem; }
    .capability-list { gap: 4.5rem; }
    .capability { gap: 1.5rem; }
    figure { width: min(100%, 284px); justify-self: start; }
  }
</style>
