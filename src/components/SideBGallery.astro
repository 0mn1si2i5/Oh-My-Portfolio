---
import Localized from './Localized.astro';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const asset = (path: string) => `${base}${path.replace(/^\//, '')}`;

const screens = [
  { file: '01-songs-home-light', caption: { en: 'Recent resolutions and a personal collection keep the next listening choice close.', zh: '最近的识别记录与个人收藏，让下一次听歌选择近在眼前。' } },
  { file: '02-paste-netease-copy', caption: { en: 'A natural-language share message can be pasted as-is; the link does not need to arrive clean.', zh: '自然语言分享消息可以原样粘贴；链接不必以规整的方式出现。' } },
  { file: '03-song-detail-creep-light', caption: { en: 'One canonical song view makes the available listening destinations legible.', zh: '统一的歌曲详情页让可用的听歌去向一目了然。' } },
  { file: '04-song-detail-reset-dark', caption: { en: 'Artwork-led detail views hold up across light and dark appearances.', zh: '以封面为主的详情页能适应浅色与深色外观。' } },
  { file: '05-rooms-list', caption: { en: 'Rooms give recommendations a small, persistent social context.', zh: '房间为推荐提供一个小而持续的社交语境。' } },
  { file: '06-room-chat-hero', caption: { en: 'Song cards, replies, and reactions remain together in the conversation.', zh: '歌曲卡片、回复与反应始终留在同一段对话里。' } },
  { file: '07-send-to-room-sheet', caption: { en: 'Sending a song is a direct continuation of resolving it.', zh: '把歌曲发到房间，是识别歌曲后的自然延续。' } },
  { file: '08-profile-settings', caption: { en: 'Profile, preferred platform, and appearance settings stay deliberately lightweight.', zh: '个人资料、偏好平台与外观设置都保持克制轻量。' } },
];
---

<section class="side-b-gallery" aria-labelledby="side-b-gallery-title">
  <div class="gallery-intro">
    <p class="eyebrow"><Localized en="In practice" zh="实际体验" /></p>
    <h2 id="side-b-gallery-title"><Localized en="From a shared link to a shared room." zh="从一条分享链接，到一个共同的房间。" /></h2>
  </div>
  <div class="screens">
    {screens.map((screen) => (
      <figure class:list={{ featured: screen.file === '06-room-chat-hero' }}>
        <img src={asset(`/media/side-b/${screen.file}.png`)} alt={screen.caption.en} data-alt-en={screen.caption.en} data-alt-zh={screen.caption.zh} loading="lazy" />
        <figcaption><Localized {...screen.caption} /></figcaption>
      </figure>
    ))}
  </div>
</section>

<style>
  .side-b-gallery { margin: 5rem 0 5.5rem; padding-top: 5rem; border-top: 1px solid var(--line); }
  .eyebrow { margin: 0; color: var(--muted); font-size: .78rem; font-weight: 650; letter-spacing: .075em; text-transform: uppercase; }
  h2 { margin: 1.1rem 0 2.8rem; font-size: clamp(2rem, 3.5vw, 3.3rem); line-height: 1; letter-spacing: -.055em; }
  .screens { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 2.2rem 1.35rem; }
  figure { margin: 0; }
  figure.featured { grid-column: 1 / -1; }
  img { display: block; width: 100%; border: 1px solid var(--line); border-radius: 14px; background: var(--surface); }
  figcaption { margin-top: .8rem; color: var(--muted); font-size: .92rem; line-height: 1.45; }
  @media (max-width: 560px) { .side-b-gallery { margin: 4rem 0; padding-top: 4rem; }.screens { grid-template-columns: 1fr; gap: 2.2rem; }.featured { grid-column: auto; } }
</style>
